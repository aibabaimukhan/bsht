function doPost(e) {
  try {
    var data = JSON.parse(e.postData.contents);
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    
    // Если пришел флаг рефлексии
    if (data.type === "reflection") {
      var sheet2 = ss.getSheetByName("Лист2"); // Убедитесь, что название совпадает
      sheet2.appendRow([
        new Date(), 
        data.fio, 
        data.group, 
        data.reflection
      ]);
    } 
    // Если пришли обычные результаты теста
    else {
      var sheet1 = ss.getSheets()[0]; // Первый лист (результаты)
      sheet1.appendRow([
        new Date(), 
        data.fio, 
        data.group, 
        data.score, 
        data.total
      ]);
    }
    
    return ContentService.createTextOutput("Success").setMimeType(ContentService.MimeType.TEXT);
    
  } catch (err) {
    return ContentService.createTextOutput("Error: " + err).setMimeType(ContentService.MimeType.TEXT);
  }
}